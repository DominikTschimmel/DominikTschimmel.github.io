		$("#title").fadeIn(500);
	});

    var img1 = new Image();
    img1.src = "images/About.jpg";
    
    var img2 = new Image();
    img2.src = "images/contact.jpg";
    
    var img3 = new Image();
    img3.src = "images/notes.jpg";

	 var img4 = new Image();
    img4.src = "images/Other_Stuff.jpg";
 
   
	Position = 1;

	$("#Home").click(function() {
		get_content("content/Home.html","Welcome",Position -1);
		Position = 1;
	});	
	
	$("#About").click(function() {
		get_content("content/About_Me.html","Short CV",Position -2);
