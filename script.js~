
	function HideOnClick() {
  	var x = document.getElementById("navigation");  	
  	if (x.style.display === "none") {
    x.style.display = "block";	 
  	} else {
    x.style.display = "none";
  	}
	}
	
	function HideMenu() {
	var y = document.getElementById("navigation");
   y.style.display = "block"; 
	}
	
