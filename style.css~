
@import url('https://fonts.googleapis.com/css?family=Open+Sans&display=swap');



* {
    padding:0;
    margin:0;
}












body {
	background-color: rgb(55, 55, 55);
	font-family: 'Open Sans', sans-serif;
}

.js-loading{
   transition: none !important;

}









#navigation{
	
   padding: 10px 0px;

	text-align:center; 	
	
 	width: 100%;
   display: block;
  	overflow: auto;
  	white-space: nowrap;
  	
  	
  	background-color: rgb(30, 30, 30);
}



.navigation_item{
	color: rgb(238, 238, 238);
	cursor: pointer;
	font-size: 16px;
	text-decoration: none;
	margin: 5px 30px; 
	
}



.navigation_item:hover{
	color: rgb(190, 190, 190);
}

















#main_content{
	
	height: auto;
	background-color: #FFF;
	box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);
	border-radius: 1px;
	
	display: block;
	margin: auto;
	margin-bottom: 40px;
	margin-top: 50px;
	padding: 10px;	
	font-weight: 300;
	font-size: 16px;
	
	position: relative;
	
	animation-name: content_slide;
	-webkit-animation-name: content_slide;
	-moz-animation-name: content_slide;
	-o-animation-name: content_slide;
	
	animation-duration: 0.6s;
	-webkit-animation-duration: 0.6s;
	-moz-animation-duration: 0.6s;
	-o-animation-duration: 0.6s;
	
	animation-timing-function: ease;
	-webkit-animation-timing-function: ease;
	-moz-animation-timing-function: ease;
	-o-animation-timing-function: ease;
	
}


#main_image{
	display:block; 
	margin: auto; 
	margin-bottom: 20px;
	overflow: hidden;

}


@media screen and (min-width: 801px){
	#main_content{ max-width: 800px;	}
	#main_image{	max-height: 400px;}
}


@media screen and (max-width: 800px){
	#main_content{ width: 90vw;	}
}







#title{   
	width: 100%;
	color: rgb(60, 60, 60);
	font-size: 60px;
	 font-weight: bold;
	text-align:  center;
	margin-top: 30px;
	
	animation-name: fade_in;
	-webkit-animation-name: fade_in;
	-moz-animation-name: fade_in;
	-o-animation-name: fade_in;
	
	animation-duration: 1s;
	-webkit-animation-duration: 1s;
	-moz-animation-duration: 1s;
	-o-animation-duration: 1s;
	
	animation-timing-function: ease;
	-webkit-animation-timing-function: ease;
	-moz-animation-timing-function: ease;
	-o-animation-timing-function: ease;
}







#notes_list{
list-style-type: disc;
margin-left: 30px;
margin-top: 30px;
}

.notes_link{
color: rgb(0, 0, 0);

font-size: 18px;
cursor: pointer;

text-decoration: underline;
font-weight: bold;
}












@keyframes content_slide {
   from {
    transform: translateY(+100vh);
    opacity: 0;
  }
	to {
    transform: translateY(0);
    opacity: 1;
  }
}


@-webkit-keyframes content_slide {
   from {
    transform: translateY(+100vh);
    opacity: 0;
  }
	to {
    transform: translateY(0);
    opacity: 1;
  }
}



@-moz-keyframes content_slide {
   from {
    transform: translateY(+100vh);
    opacity: 0;
  }
	to {
    transform: translateY(0);
    opacity: 1;
  }
}



@-o-keyframes content_slide {
   from {
    transform: translateY(+100vh);
    opacity: 0;
  }
	to {
    transform: translateY(0);
    opacity: 1;
  }
}







@keyframes fade_in {
   from {
    opacity: 0;
  }
	to {
    opacity: 1;
  }
}



@-webkit-keyframes fade_in {
   from {
    opacity: 0;
  }
	to {
    opacity: 1;
  }
}



@-moz-keyframes fade_in {
   from {
    opacity: 0;
  }
	to {
    opacity: 1;
  }
}




@-o-keyframes fade_in {
   from {
    opacity: 0;
  }
	to {
    opacity: 1;
  }
}




		
