
@import url('https://fonts.googleapis.com/css?family=Roboto');



* {
    padding:0;
    margin:0;
}



/* body*/

body {
	background-color: rgb(238, 238, 238);
	font-family: 'Roboto', sans-serif;
}

header {
	background-color: rgb(58, 58, 58);
	width: 100%;
	height: 100px;
	margin: 0; 
	padding: 0;
}

.header_name{
	float: left;
	color: rgb(250, 250, 250);
	padding-top: 40px;
	padding-left: 50px;
	font-weight: 300;
}

.header_menu{
	float: right;
	color: rgb(250, 250, 250);
	padding-top: 40px;
	padding-right: 50px;
	cursor: pointer;
}


.content_box{
margin: auto;
}



.main_content{
	
	max-width: 800px;
	background-color: #FFF;
	box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);
	border-radius: 1px;
	margin: auto;
	padding: 10px;	
	font-weight: 300;
	font-size: 16px;
	
	position: relative;
	animation-name: content_slide;
	animation-duration: 0.6s;
}

@keyframes content_slide {
   from {
    transform: translateX(+100%);
    opacity: 0;
  }
	to {
    transform: translateX(0);
    opacity: 1;
  }
}



#notes_list{
list-style-type: none;
}

.notes_link{
color: rgb(0, 0, 0);

font-size: 18px;
cursor: pointer;

text-decoration: underline;
font-weight: bold;
}


#navigation{
   padding: 20px 0px;
   
	list-style-type: none;   
   
   background-color: rgb(58, 58, 58);
   box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);
  	border-radius: 1px;
  	
  	position:relative;
  	transition: 0.25s;
  	overflow: hidden;
}


.navigation_item{
	
	color: rgb(250, 250, 250);

	
	cursor: pointer;
	font-size: 18px;
	text-decoration: none;
}



.navigation_item:hover{
	background-color: rgb(100, 100, 100);
	border-radius: 1px;
}

#active_link{
	background-color: rgb(100, 100, 100);
	border-radius: 1px;

}









@media screen and (min-width: 1051px){

.content_box{
	padding-top: 100px;
	width: 1050px;
}

.main_content{
	width: 800px;
	float: right;
}

#navigation{
	float: left;
   width: 200px;
   margin: 0;
   display: block;
}

.navigation_item{
	margin: 5px 20px;
	padding: 20px 10px; 
}




.header_menu{
	display: none;
}

}
		
@media screen and (max-width: 1050px){
	
.content_box{
	padding-top: 20px;
	width: 98vw;
}
	



#navigation{
   width: 98vw;
   max-width: 820px;
   margin: auto;
   margin-bottom: 20px;
   display: none;
   
   animation-name: menu_scroll;
	animation-duration: 0.5s;
}


@keyframes menu_scroll {
   from {
    max-height: 1px;
    opacity: 0;
  }
	to {
     max-height: 1000px;
     opacity: 1;
  }
}

.navigation_item{
	margin 20px;
	padding: 20px 10px; 
	text-align: center;
}

	
}


@media screen and (max-width: 500px){
	.header_name{
	display: none;
}
}

