
@import url('https://fonts.googleapis.com/css?family=Open+Sans&display=swap');



* {
    padding:0;
    margin:0;
}




li {
    margin-bottom: 20px;
}







body {
	background-color: rgb(55, 55, 55);
	font-family: 'Lato', sans-serif;
}

.js-loading{
   transition: none !important;

}









#navigation{
	
   padding: 10px 0px;

	text-align:center; 	
	
	position: fixed;
	z-index: 100;
	top: 0px;
 	width: 100%;
   display: block;
  	overflow: auto;
  	white-space: nowrap;
  	
  	
  	background-color: rgb(30, 30, 30);

    
}


.navigation_item{
	color: rgb(238, 238, 238);
	cursor: pointer;
	font-size: 16px;
	text-decoration: none;
	margin: 5px 30px; 
}



.navigation_item:hover{
	color: rgb(190, 190, 190);
}







#title{   
	width: 100%;
	color: rgb(65, 65, 65);
	font-size: 60px;
	 font-weight: bold;
	text-align:  center;
	margin-top: 80px;
}










.main_content{
	
	height: auto;
	background-color: #FFF;
	box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);
	border-radius: 1px;
	
	display: block;
	margin: auto;
	margin-bottom: 40px;
	margin-top: 50px;
	padding: 10px;	
	font-weight: 400;
	color: rgb(25,25,25);
	font-size: 18px;
	
	position: relative;
	
	
	
}


.main_image{
	display:block; 
	margin: auto; 
	margin-bottom: 20px;
	overflow: hidden;

}


@media screen and (min-width: 821px){
	.main_content{ max-width: 800px;	}
	.main_image{	max-height: 400px;}
}


@media screen and (max-width: 820px){
	.main_content{ width: 90vw;	}
}




















		
